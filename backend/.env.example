# JWT authentication secret. Change this to a strong random value in production.
JWT_SECRET_KEY=your-secret-key-here-change-in-production

# Async database connection URL.
DATABASE_URL=sqlite+aiosqlite:///./robonexus.db

# Comma-separated list of allowed CORS origins.
CORS_ORIGINS=http://localhost:5500,https://zhouyubo868-bot.github.io
